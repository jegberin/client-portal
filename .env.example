# Database
DATABASE_URL="postgresql://atrium:atrium@localhost:5432/atrium?schema=public"

# Better Auth
BETTER_AUTH_SECRET="change-me-in-production"
BETTER_AUTH_URL="http://localhost:3001"

# App URLs
API_URL="http://localhost:3001"
WEB_URL="http://localhost:3000"

# Storage: local | minio | s3 | r2
STORAGE_PROVIDER="local"
UPLOAD_DIR="./uploads"

# MinIO / S3 / R2 (when STORAGE_PROVIDER != local)
S3_ENDPOINT=""
S3_REGION="us-east-1"
S3_BUCKET="atrium"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# Resend (email)
RESEND_API_KEY=""
EMAIL_FROM="noreply@atrium.local"

# File upload
MAX_FILE_SIZE_MB="50"

# Logging
LOG_LEVEL="info"
